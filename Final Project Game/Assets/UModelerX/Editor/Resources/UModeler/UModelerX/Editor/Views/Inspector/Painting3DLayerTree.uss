/* Painting3DLayerTreeElement: 페인팅 레이어 트리 커스텀 VisualElement 스타일 */

/* ========== 루트 컨테이너 (모디파이어 뷰 통일) ========== */
.painting3d-layer-tree {
    background-color: var(--umx-bg-surface);
    border-width: 1px;
    border-color: var(--umx-border-strong);
    border-radius: 4px;
    margin-bottom: 6px;
    margin-left: 8px;
    margin-right: 8px;
    flex-shrink: 0;
    overflow: hidden;
}

/* ========== 공용 패널 헤더 (모디파이어 뷰 통일) ========== */
.painting3d-panel-header {
    background-color: var(--umx-bg-surface);
    padding-top: 8px;
    padding-bottom: 4px;
    padding-left: 10px;
    padding-right: 10px;
    border-bottom-width: 0;
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    cursor: link;
}

/* 헤더 호버 효과 */
.painting3d-panel-header:hover {
    background-color: var(--umx-bg-elevated);
}

/* 헤더 아이콘 */
.painting3d-panel-header__icon {
    width: 28px;
    height: 28px;
    margin-right: 4px;
    flex-shrink: 0;
}

/* 헤더 타이틀 */
.painting3d-panel-header__title {
    -unity-font-style: bold;
    font-size: 12px;
    color: var(--umx-text-secondary);
    flex-grow: 1;
}

/* ========== 레이어 컨텐츠 영역 (모디파이어 뷰 통일) ========== */
.painting3d-layer-content {
    margin: 4px;
    border-width: 1px;
    border-color: var(--umx-border-strong);
    border-radius: 0;
    background-color: var(--umx-bg-content);
    min-height: 0;
    max-height: 400px;
    flex-shrink: 0;
}

/* 레이어 컨텐츠 내부 스크롤뷰 */
.painting3d-layer-content ScrollView {
    flex-grow: 1;
}

/* 스크롤뷰 내부 콘텐츠 컨테이너 */
.painting3d-layer-content ScrollView #unity-content-container {
    flex-grow: 0;
    flex-shrink: 0;
}

/* 상태바 스페이서 */
.painting3d-status-bar__spacer {
    flex-grow: 1;
}

/* 상태바 버튼 컨테이너 */
.painting3d-status-bar__buttons {
    flex-direction: row;
    flex-shrink: 0;
}

/* ========== 레이어 아이템 ========== */
.painting3d-layer-item {
    flex-direction: row;
    align-items: center;
    height: 54px;
    padding-left: 4px;
    padding-right: 2px;
    margin-bottom: 1px;
    background-color: var(--umx-bg-content);
    flex-shrink: 0;
    overflow: hidden;
}

/* 레이어 아이템 호버 효과 */
.painting3d-layer-item:hover {
    background-color: var(--umx-bg-hover);
}

/* 선택된 레이어 */
.painting3d-layer-item--selected {
    background-color: var(--umx-selection);
}

/* 선택된 레이어 호버 효과 */
.painting3d-layer-item--selected:hover {
    background-color: var(--umx-selection-hover);
}

/* 타입 아이콘 */
.layer-type-icon {
    width: 20px;
    min-width: 20px;
    height: 20px;
    font-size: 14px;
    -unity-text-align: middle-center;
    color: var(--umx-text-tertiary);
    flex-shrink: 0;
}

/* 가시성 체크박스 */
.layer-visible-toggle {
    margin-left: 2px;
    margin-right: 4px;
    width: 16px;
    flex-shrink: 0;
}

/* 썸네일 */
.layer-thumbnail {
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    margin-right: 3px;
    flex-shrink: 0;
    background-color: var(--umx-bg-elevated);
    border-width: 1px;
    border-color: var(--umx-border-subtle);
}

/* 레이어 썸네일 선택 상태 (마스크 미선택 = 레이어 편집 중) */
.layer-thumbnail--selected {
    border-color: var(--umx-text-secondary);
}

/* 마스크 썸네일 */
.layer-mask-thumb {
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    margin-right: 3px;
    flex-shrink: 0;
    background-color: var(--umx-bg-elevated);
    border-width: 1px;
    border-color: var(--umx-border-subtle);
}

/* 마스크 선택 상태 */
.layer-mask-thumb--selected {
    border-color: var(--umx-text-secondary);
}

/* 이름 컨테이너 */
.layer-name-box {
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
    justify-content: center;
    min-width: 30px;
}

/* 이름 라벨 */
.layer-name-label {
    font-size: 11px;
    color: var(--umx-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
}

/* 우측 컬럼 (블렌드 + 오파시티) */
.layer-right-col {
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    width: 68px;
    min-width: 68px;
    flex-shrink: 0;
}

/* 블렌드 타입 버튼 */
.layer-blend-btn {
    font-size: 9px;
    height: 16px;
    width: 64px;
    margin-bottom: 2px;
    padding-left: 2px;
    padding-right: 2px;
}

/* 오파시티 행 */
.layer-opacity-row {
    flex-direction: row;
    align-items: center;
    height: 16px;
}

/* 오파시티 인풋 필드 */
.layer-opacity-field {
    width: 40px;
    height: 16px;
    font-size: 10px;
}

/* 오파시티 드롭 버튼 */
.layer-opacity-drop-btn {
    width: 16px;
    height: 16px;
    font-size: 8px;
    padding-left: 0;
    padding-right: 0;
    margin-left: 0;
}

/* 3점 메뉴 버튼 */
.layer-menu-btn {
    width: 14px;
    min-width: 14px;
    height: 46px;
    font-size: 14px;
    background-color: transparent;
    border-width: 0;
    color: var(--umx-text-muted);
    flex-shrink: 0;
}

/* 3점 메뉴 버튼 호버 효과 */
.layer-menu-btn:hover {
    color: var(--umx-text-secondary);
}

/* ========== 상태바 ========== */
.painting3d-status-bar {
    flex-direction: row;
    align-items: center;
    height: 24px;
    padding-left: 4px;
    padding-right: 4px;
    background-color: var(--umx-bg-content);
    flex-shrink: 0;
}

/* 상태바 버튼 */
.painting3d-status-btn {
    width: 12px;
    height: 12px;
    font-size: 10px;
    margin-left: 3px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
    padding: 2px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
}

/* ========== 오파시티 슬라이더 팝업 ========== */
.painting3d-opacity-popup {
    position: absolute;
    width: 140px;
    height: 28px;
    background-color: var(--umx-bg-elevated);
    border-width: 1px;
    border-color: var(--umx-border-faint);
    padding-left: 4px;
    padding-right: 4px;
}

/* 오파시티 팝업 내부 슬라이더 */
.painting3d-opacity-popup SliderInt {
    flex-grow: 1;
}

/* ========== Small 모드 ========== */
.painting3d-layer-item--small {
    height: 28px;
    padding-left: 2px;
    padding-right: 2px;
}

/* Small 모드 타입 아이콘 */
.layer-type-icon--small {
    width: 16px;
    min-width: 16px;
    height: 16px;
    font-size: 11px;
}

/* Small 모드 썸네일 */
.layer-thumbnail--small {
    width: 20px;
    height: 20px;
    min-width: 20px;
    min-height: 20px;
}

/* Small 모드 마스크 썸네일 */
.layer-mask-thumb--small {
    width: 20px;
    height: 20px;
    min-width: 20px;
    min-height: 20px;
}

/* Small 모드 우측 컬럼 (가로 배치로 변경) */
.layer-right-col--small {
    flex-direction: row;
    align-items: center;
    width: auto;
    min-width: auto;
}

/* Small 모드 블렌드 타입 버튼 */
.layer-blend-btn--small {
    font-size: 9px;
    height: 16px;
    width: 52px;
    margin-bottom: 0;
    margin-right: 2px;
}

/* Small 모드 오파시티 인풋 필드 */
.layer-opacity-field--small {
    width: 32px;
    height: 16px;
    font-size: 10px;
}

/* Small 모드 오파시티 드롭 버튼 */
.layer-opacity-drop-btn--small {
    width: 14px;
    height: 16px;
    font-size: 7px;
    padding-left: 0;
    padding-right: 0;
    margin-left: 0;
}

/* Small 모드 3점 메뉴 버튼 */
.layer-menu-btn--small {
    height: 24px;
    font-size: 12px;
}

/* ========== 드래그 드롭 인디케이터 ========== */
.painting3d-drag-indicator {
    position: absolute;
    height: 2px;
    left: 0;
    right: 0;
    background-color: var(--umx-drag);
}

/* ========== 드래그 고스트 ========== */
.painting3d-drag-ghost {
    position: absolute;
    left: 0;
    right: 0;
    background-color: rgba(51, 102, 179, 0.3);
}
