                                <ui:Button name="tripo-remesh-pivot-bottom-button" text="Bottom" class="toggle-button left on" />
                                <ui:Button name="tripo-remesh-pivot-center-button" text="Center" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Poly Count" class="property label" />
