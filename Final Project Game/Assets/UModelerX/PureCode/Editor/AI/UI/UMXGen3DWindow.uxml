                                <ui:Button name="tripo-imageTo3D-smartLow-on-button" text="On" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Texturing" class="property label" />
                            <ui:VisualElement class="toggle-group-background">
                                <ui:Button name="tripo-imageTo3D-texturing-off-button" text="Off" class="toggle-button left" />
                                <ui:Button name="tripo-imageTo3D-texturing-on-button" text="On" class="toggle-button middle on" />
                                <ui:Button name="tripo-imageTo3D-texturing-pbr-button" text="PBR" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label name="tripo-imageTo3D-hdTexture-label" text="HD Texture" class="property label" />
