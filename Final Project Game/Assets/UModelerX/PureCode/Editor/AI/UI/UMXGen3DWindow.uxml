                                <ui:Button name="tripo-imageTo3D-textureSeed-fixed-button" text="Fixed" class="toggle-button right" />
                            </ui:VisualElement>
                            <uie:IntegerField name="tripo-imageTo3D-textureSeed-input" class="int-input" />
                        </ui:VisualElement>
