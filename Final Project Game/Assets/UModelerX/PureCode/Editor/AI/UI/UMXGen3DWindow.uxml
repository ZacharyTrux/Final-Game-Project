                    <ui:VisualElement name="tripo-props-texture" class="props hidden">
                        <ui:VisualElement name="tripo-texture-prompt-row" class="property grow hidden">
                            <ui:Label text="Prompt" class="property big-label" />
                            <ui:TextField name="tripo-texture-prompt" placeholder-text="Describe how you want your mesh to be textured. e.g. metallic surface, stylized wood, painted look." multiline="true" class="prompt-text-field" />
                            <ui:Label name="tripo-texture-prompt-counter" text="0/800" class="textfield-counter" />
                        </ui:VisualElement>
                        <ui:VisualElement name="tripo-texture-image-row" class="property grow hidden">
                            <ui:Label text="Image" class="property big-label" />
                            <ui:Button name="tripo-texture-image-button" class="property image" />
                        </ui:VisualElement>
                        <ui:VisualElement class="property row">
                            <ui:Label text="AI Model" class="property label" />
                            <ui:VisualElement name="tripo-texture-aiModel" class="dropdown-field" />
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Input" class="property label" />
