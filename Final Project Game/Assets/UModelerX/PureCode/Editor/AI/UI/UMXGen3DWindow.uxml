                                <ui:Button name="tripo-imageTo3D-hdTexture-on-button" text="On" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Poly Count" class="property label" />
                            <ui:SliderInt name="tripo-imageTo3D-polyCount-slider" class="property slider-field" />
                            <uie:IntegerField name="tripo-imageTo3D-polyCount-input" class="int-input" />
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Model Seed" class="property label" />
                            <ui:VisualElement class="toggle-group-background">
                                <ui:Button name="tripo-imageTo3D-modelSeed-random-button" text="Random" class="toggle-button left on" />
                                <ui:Button name="tripo-imageTo3D-modelSeed-fixed-button" text="Fixed" class="toggle-button right" />
                            </ui:VisualElement>
                            <uie:IntegerField name="tripo-imageTo3D-modelSeed-input" class="int-input" />
