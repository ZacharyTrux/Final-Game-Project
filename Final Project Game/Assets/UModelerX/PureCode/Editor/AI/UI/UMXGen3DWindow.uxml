                                <ui:Button name="tripo-texture-input-image-button" text="Image" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="tripo-texture-texturing" class="property row toggle-group">
