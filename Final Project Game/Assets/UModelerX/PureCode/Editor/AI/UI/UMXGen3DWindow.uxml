                                <ui:Button name="tripo-texture-texturing-on-button" text="On" class="toggle-button left on" />
                                <ui:Button name="tripo-texture-texturing-pbr-button" text="PBR" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="tripo-texture-hdTexture" class="property row toggle-group">
                            <ui:Label name="tripo-texture-hdTexture-label" text="HD Texture" class="property label"/>
                            <ui:VisualElement class="toggle-group-background">
                                <ui:Button name="tripo-texture-hdTexture-off-button" text="Off" class="toggle-button left on" />
                                <ui:Button name="tripo-texture-hdTexture-on-button" text="On" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label text="Alignment" class="property label" />
                            <ui:VisualElement class="toggle-group-background">
                                <ui:Button name="tripo-texture-alignment-image-button" text="Image" class="toggle-button left on" />
                                <ui:Button name="tripo-texture-alignment-geometry-button" text="Geometry" class="toggle-button right" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="property row toggle-group">
                            <ui:Label name="tripo-texture-textureSeed-label" text="Texture Seed" class="property label" />
                            <ui:VisualElement class="toggle-group-background">
                                <ui:Button name="tripo-texture-textureSeed-random-button" text="Random" class="toggle-button left on" />
                                <ui:Button name="tripo-texture-textureSeed-fixed-button" text="Fixed" class="toggle-button right" />
                            </ui:VisualElement>
                            <uie:IntegerField name="tripo-texture-textureSeed-input" class="int-input" />
                        </ui:VisualElement>
                    </ui:VisualElement>

                    <ui:VisualElement name="generate-tab" class="generate-row">
                      <ui:Label name="generate-tooltip" text="Please enter the prompt before generating." class="generate-tooltip" />
                      <ui:VisualElement name="generate-group" class="generate-group">
                        <ui:VisualElement name="cost-tab" class="cost-tab">
                          <ui:Image class="credit-icon-lg" />
                          <ui:Label text="15" name="credit-cost" class="credit-cost bold" />
                        </ui:VisualElement>
                        <ui:Button name="btn-generate" text="Generate" class="generate bold enable">
                          <ui:VisualElement name="loading" class="loading-background hidden">
                            <ui:VisualElement name="loading-progress" class="loading-progress" />
                          </ui:VisualElement>
                        </ui:Button>
                      </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
