                        <ui:VisualElement name="tripo-imageTo3D-multiImage-group" class="property multi-image-group hidden">
                            <ui:Button name="tripo-imageTo3D-multiImage-front-button" text="Front" class="property multi-image" />
                            <ui:Button name="tripo-imageTo3D-multiImage-left-button" text="Left" class="property multi-image" />
                            <ui:Button name="tripo-imageTo3D-multiImage-back-button" text="Back" class="property multi-image" />
                            <ui:Button name="tripo-imageTo3D-multiImage-right-button" text="Right" class="property multi-image" />
